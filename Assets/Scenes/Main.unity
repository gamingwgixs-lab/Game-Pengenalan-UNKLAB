    - target: {fileID: 7974457891315710290, guid: 16688d67522b20349bcaaf178e9c54c6, type: 3}
      propertyPath: 'dialogueParagraphs.Array.data[0]'
      value: Hai! Saya Jimmy Moedjahedy, Kaprodi Sistem Informasi. Di sini, fokus

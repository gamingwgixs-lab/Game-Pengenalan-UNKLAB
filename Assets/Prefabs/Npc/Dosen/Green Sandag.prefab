  m_Script: {fileID: 11500000, guid: dfed6c4a5c3ba3843a3bcc508138024e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: Green Sandag
  npcPortrait: {fileID: 21300000, guid: 52768d2e4f5b0a5409f56e9640170157, type: 3}
  tipeVisual: 1
  dialogueParagraphs:
  - Halo! Selamat datang di ruangan komputer 503. Nama saya Sir Green Sandag.
  - Di sini saya mengajar tentang kecerdasan buatan supaya komputer bisa belajar dan berpikir sendiri lho.
  - Senang sekali bisa menyapa kamu di lingkungan Filkom ini!
  - Kalau ada yang mau kamu tanyakan soal dunia AI jangan ragu buat bicara ya!
